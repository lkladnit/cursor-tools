```bash
# Generate baselines (first run / after intentional changes)
npx playwright test --config=playwright/playwright.config.ts --project=VisualRegression --update-snapshots

# Detect regressions
npx playwright test --config=playwright/playwright.config.ts --project=VisualRegression

# Single spec
npx playwright test --config=playwright/playwright.config.ts --project=VisualRegression tests/visual/visual-vm-list.spec.ts
```

