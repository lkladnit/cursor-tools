## Creating a New PageObject

File: `playwright/src/page-objects/<feature>-page.ts`

**Locator rule**: Define locators inline in the method. Extract to `private readonly` only when used by 2+ methods.

```typescript
import { Page } from '@playwright/test';
import BasePage from './base-page';

export default class MyPage extends BasePage {
  constructor(page: Page) { super(page); }

  // Class property: used by fillName() AND clearName()
  private readonly _nameInput = this.locator('#name-input');

  async clickActionButton(): Promise<void> {
    await this.robustClick(this.locator('[data-test="my-action"]'));
  }

  async fillName(name: string): Promise<void> {
    await this._nameInput.fill(name);
  }

  async clearName(): Promise<void> {
    await this._nameInput.clear();
  }

  async verifyResult(): Promise<boolean> {
    return await this.locator('[data-test="result-text"]').isVisible();
  }

  async navigateToFeaturePage(namespace: string): Promise<void> {
    await this.goTo(`/k8s/ns/${namespace}/my-feature`);
  }
}
```

