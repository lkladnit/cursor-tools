## Spec File Structure

```typescript
/**
 * Release 4.XX — Playwright E2E for CNV release 4.XX
 * Source of truth: this file (no Cypress sync)
 */

import { execSync } from 'child_process';
import type { Page } from '@playwright/test';

import { expect, test } from '@/fixtures/releases-fixture';
import { TEMPLATE_METADATA_NAMES } from '@/utils/template-constants';
import { TestTimeouts } from '@/utils/test-config';
import { VM_STATUS, VM_ACTION } from '@/data-models/constants';

// ─── constants ────────────────────────────────────────────────────────────────
const TEST_VM_NAME = 'auto-test-vm';
const TEST_IT_NAME = 'auto-it-vm';

// ─── selectors ────────────────────────────────────────────────────────────────
const vmNav = '[data-test-id="virtualmachines-nav-item"]';

// ─── helpers ──────────────────────────────────────────────────────────────────
async function waitForVmStatus(page: Page, vmName: string, status: string): Promise<void> { ... }

// ─── test suites ──────────────────────────────────────────────────────────────
test.describe('cypress_tests_gating_gating_tabs-are-loaded', { tag: ['@release-4.XX', '@gating-4.XX', '@priv-4.XX'] }, () => {
  test('ID(CNV-XXXXX) tab loads', async ({ page, testConfig }) => { ... });
});
```

